generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  password    String
  role        String   @default("CUSTOMER")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  carBrand    String?
  carModel    String?
  phone       String?
  address     String?
  earnings    Float    @default(0)

  companyName String?
  website     String?
  siret       String?

  bookings    Booking[]
  ads         Ad[]

  @@map("users")
}

model Ad {
  id              String   @id @default(cuid())
  title           String
  description     String
  imageUrl        String?
  pricePerDay     Float
  totalBudget     Float
  remainingBudget Float
  isActive        Boolean  @default(true)
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  advertiserId    String
  advertiser      User     @relation(fields: [advertiserId], references: [id])

  eligibleModels  AdCarModel[]
  bookings        Booking[]

  @@map("ads")
}

model AdCarModel {
  id    String @id @default(cuid())
  adId  String
  brand String
  model String

  ad    Ad     @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@unique([adId, brand, model])
  @@map("ad_car_models")
}

model Booking {
  id          String    @id @default(cuid())
  userId      String
  adId        String
  status      String    @default("PENDING")
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  earnings    Float     @default(0)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id])
  ad          Ad        @relation(fields: [adId], references: [id])

  @@map("bookings")
}
